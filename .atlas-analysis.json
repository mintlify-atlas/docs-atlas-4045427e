  "keyFeatures": [
    "O(1) bump-pointer allocation with single bounds check",
    "RAII transactions with auto-rollback on drop",
    "Nested savepoints to arbitrary depth",
    "ArenaVec growable vector backed by arena memory",
    "Zero-cost reset — pages stay mapped, no OS calls",
    "Transaction budget enforcement for request-scoped safety",
    "Optional LIFO drop-tracking via feature flag",
    "ArenaBox owned allocation without heap",
    "Fallible allocation variants returning Option",
    "Zero external dependencies"
  ],
